{
  "name": "frontend",
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "clean": "turbo run clean",
    "build": "turbo run build",
    "dev": "turbo run dev --filter=\"@telemetryslice/next\"",
    "env-check:common": "dotenv-checker --schema .env.example --env .env"
  },
  "devDependencies": {
    "turbo": "^2.8.12"
  }
}
